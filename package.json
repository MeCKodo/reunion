{
  "name": "reunion",
  "productName": "Reunion",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/electron/bootstrap.cjs",
  "description": "Reunite with every AI conversation. Aggregate, search, read and export local Cursor / Claude Code / Codex agent chats.",
  "author": "MeCKodo",
  "scripts": {
    "index": "tsx src/server.ts index",
    "serve": "tsx src/server.ts serve --port 9765",
    "build:frontend": "pnpm -C frontend run build",
    "build:backend": "node scripts/build-electron.mjs",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:icons": "node scripts/generate-icons.mjs",
    "start": "node dist/src/server.cjs",
    "electron": "pnpm run build && electron .",
    "dist:mac": "pnpm run build && electron-builder --mac --config electron-builder.yml",
    "dist:mac:arm64": "pnpm run build && electron-builder --mac --arm64 --config electron-builder.yml",
    "dist:mac:x64": "pnpm run build && electron-builder --mac --x64 --config electron-builder.yml",
    "dist:win": "pnpm run build && electron-builder --win --config electron-builder.yml",
    "dist:win:x64": "pnpm run build && electron-builder --win --x64 --config electron-builder.yml",
    "dist:win:arm64": "pnpm run build && electron-builder --win --arm64 --config electron-builder.yml",
    "dist:all": "pnpm run build && electron-builder --mac --win --config electron-builder.yml",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh --bump patch",
    "release:minor": "bash scripts/release.sh --bump minor",
    "release:draft": "bash scripts/release.sh --draft"
  },
  "dependencies": {
    "fix-path": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
